"Validation",
"Random Forest",
valid_df$target_log_incidence,
rf_valid_pred_log,
valid_df$dengue_cases_target,
valid_df$estimated_population
),
metric_row(
"Validation",
"LightGBM",
valid_df$target_log_incidence,
lgb_valid_pred_log,
valid_df$dengue_cases_target,
valid_df$estimated_population
),
metric_row(
"Validation",
"XGBoost",
valid_df$target_log_incidence,
xgb_valid_pred_log,
valid_df$dengue_cases_target,
valid_df$estimated_population
)
) %>%
arrange(RMSE_raw)
test_results <- bind_rows(
metric_row(
"Test",
"Random Forest",
test_df$target_log_incidence,
rf_test_pred_log,
test_df$dengue_cases_target,
test_df$estimated_population
),
metric_row(
"Test",
"LightGBM",
test_df$target_log_incidence,
lgb_test_pred_log,
test_df$dengue_cases_target,
test_df$estimated_population
),
metric_row(
"Test",
"XGBoost",
test_df$target_log_incidence,
xgb_test_pred_log,
test_df$dengue_cases_target,
test_df$estimated_population
)
) %>%
arrange(RMSE_raw)
cat("\n==============================\n")
cat("VALIDATION RESULTS\n")
cat("==============================\n")
print(validation_results, width = Inf)
cat("\n==============================\n")
cat("TEST RESULTS\n")
cat("==============================\n")
print(test_results, width = Inf)
# ----------------------------
# 17. Prediction table
# ----------------------------
prediction_table <- test_df %>%
select(
year,
week,
any_of("barangay"),
dengue_cases_target,
estimated_population,
dengue_incidence_per_10k,
target_log_incidence
) %>%
mutate(
RF_pred_log_incidence = rf_test_pred_log,
LightGBM_pred_log_incidence = lgb_test_pred_log,
XGBoost_pred_log_incidence = xgb_test_pred_log,
RF_pred_incidence_per_10k = loginc_to_incidence(RF_pred_log_incidence),
LightGBM_pred_incidence_per_10k = loginc_to_incidence(LightGBM_pred_log_incidence),
XGBoost_pred_incidence_per_10k = loginc_to_incidence(XGBoost_pred_log_incidence),
RF_pred_cases = loginc_to_cases(RF_pred_log_incidence, estimated_population),
LightGBM_pred_cases = loginc_to_cases(LightGBM_pred_log_incidence, estimated_population),
XGBoost_pred_cases = loginc_to_cases(XGBoost_pred_log_incidence, estimated_population)
)
cat("\n==============================\n")
cat("SAMPLE TEST PREDICTIONS\n")
cat("==============================\n")
print(head(prediction_table, 20), width = Inf)
# ----------------------------
# 18. Feature importance
# ----------------------------
rf_importance <- tibble(
Feature = names(rf_model$variable.importance),
Importance = as.numeric(rf_model$variable.importance)
) %>%
arrange(desc(Importance)) %>%
mutate(Model = "Random Forest") %>%
select(Model, Feature, Importance)
lgb_importance <- lgb.importance(
model = lgb_model,
percentage = TRUE
) %>%
as_tibble() %>%
transmute(
Model = "LightGBM",
Feature = Feature,
Importance = Gain
) %>%
arrange(desc(Importance))
xgb_importance_raw <- xgb.importance(
feature_names = sparse_data$feature_names,
model = xgb_model
)
xgb_importance <- xgb_importance_raw %>%
as_tibble() %>%
transmute(
Model = "XGBoost",
Feature = Feature,
Importance = Gain
) %>%
arrange(desc(Importance))
importance_table <- bind_rows(
rf_importance,
lgb_importance,
xgb_importance
)
cat("\n==============================\n")
cat("TOP FEATURE IMPORTANCE\n")
cat("==============================\n")
print(
importance_table %>%
group_by(Model) %>%
slice_max(order_by = Importance, n = 20, with_ties = FALSE) %>%
ungroup(),
width = Inf
)
# ----------------------------
# 19. Save results
# ----------------------------
output_path <- "C:/Users/Christopher/Downloads/dengue_dataset_only_regressor_results_with_raw_cases.xlsx"
used_features_table <- tibble(
Feature = feature_cols
)
excluded_features_table <- tibble(
Excluded_Requested_Feature = excluded_requested_features
)
target_summary_table <- tibble(
Target = "target_log_incidence",
Target_Formula = "log1p(dengue_incidence_per_10k)",
Incidence_Formula = "dengue_cases / estimated_population * 10000",
Population_Formula = "pop_density * barangay_area_km2",
Case_Column_Used = case_col,
Test_Start_Year = test_start_year,
Validation_Year = validation_year,
Train_Min_Year = min(train_df$year),
Train_Max_Year = max(train_df$year),
Test_Min_Year = min(test_df$year),
Test_Max_Year = max(test_df$year),
LightGBM_Best_Iteration = lgb_best_iter,
XGBoost_Best_Iteration = xgb_best_iter
)
wb <- createWorkbook()
addWorksheet(wb, "target_summary")
writeData(wb, "target_summary", target_summary_table)
addWorksheet(wb, "validation_results")
writeData(wb, "validation_results", validation_results)
addWorksheet(wb, "test_results")
writeData(wb, "test_results", test_results)
addWorksheet(wb, "test_predictions")
writeData(wb, "test_predictions", prediction_table)
addWorksheet(wb, "used_features")
writeData(wb, "used_features", used_features_table)
addWorksheet(wb, "excluded_features")
writeData(wb, "excluded_features", excluded_features_table)
addWorksheet(wb, "feature_importance")
writeData(wb, "feature_importance", importance_table)
saveWorkbook(wb, output_path, overwrite = TRUE)
cat("\n==============================\n")
cat("DONE\n")
cat("==============================\n")
cat("Results saved to:\n")
cat(output_path, "\n")
cat("\nBest model by TEST raw-case RMSE:\n")
print(test_results %>% slice(1), width = Inf)
# ============================================================
# CITY-WIDE TEMPORAL PLOTS OF DENGUE CASES
# To show that dengue cases peak during the wet season
# ============================================================
# ------------------------------------------------------------
# 0. INSTALL AND LOAD PACKAGES
# ------------------------------------------------------------
packages <- c(
"readxl", "dplyr", "ggplot2", "lubridate",
"ISOweek", "scales", "stringr"
)
installed <- rownames(installed.packages())
for (p in packages) {
if (!(p %in% installed)) {
install.packages(p)
}
}
library(readxl)
library(dplyr)
library(ggplot2)
library(lubridate)
library(ISOweek)
library(scales)
library(stringr)
# ------------------------------------------------------------
# 1. FILE PATHS
# ------------------------------------------------------------
dataset_path <- "C:/Users/Christopher/Downloads/FINAL DENGUE CODES AND FILES/FINAL_DATASET.xlsx"
output_dir   <- "C:/Users/Christopher/Downloads/FINAL DENGUE CODES AND FILES/DENGUE_GIS_OUTPUTS"
if (!dir.exists(output_dir)) {
dir.create(output_dir)
}
# ------------------------------------------------------------
# 2. READ DATA
# ------------------------------------------------------------
dengue_df <- read_excel(dataset_path)
# Required columns
required_cols <- c("barangay", "year", "week", "dengue_cases")
missing_cols <- setdiff(required_cols, names(dengue_df))
if (length(missing_cols) > 0) {
stop(
paste(
"Missing required columns in FINAL_DATASET.xlsx:",
paste(missing_cols, collapse = ", ")
)
)
}
# ------------------------------------------------------------
# 3. CREATE A TRUE WEEK DATE USING ISO YEAR-WEEK
# ------------------------------------------------------------
# This creates the Monday of each ISO week.
# Example: year = 2015, week = 1 becomes 2014-12-29,
# which is correct for ISO week 1 of 2015.
dengue_df <- dengue_df %>%
mutate(
iso_week_string = paste0(year, "-W", str_pad(week, width = 2, pad = "0"), "-1"),
week_start_date = ISOweek2date(iso_week_string)
)
# ------------------------------------------------------------
# 4. AGGREGATE TO CITY-WIDE WEEKLY CASES
# ------------------------------------------------------------
citywide_weekly <- dengue_df %>%
group_by(year, week, week_start_date) %>%
summarise(
citywide_dengue_cases = sum(dengue_cases, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(week_start_date) %>%
mutate(
month = month(week_start_date),
month_label = month(week_start_date, label = TRUE, abbr = TRUE)
)
# ------------------------------------------------------------
# 5. CREATE WET SEASON SHADING DATA
# Wet season assumed as June 1 to November 30 each year
# ------------------------------------------------------------
years_in_data <- sort(unique(citywide_weekly$year))
wet_season_df <- data.frame(
xmin = as.Date(paste0(years_in_data, "-06-01")),
xmax = as.Date(paste0(years_in_data, "-11-30")),
ymin = -Inf,
ymax = Inf
)
# ------------------------------------------------------------
# 6. PLOT 1: WEEKLY CITY-WIDE DENGUE TIME SERIES
# WITH WET SEASON SHADING
# ------------------------------------------------------------
plot_weekly <- ggplot() +
geom_rect(
data = wet_season_df,
aes(xmin = xmin, xmax = xmax, ymin = ymin, ymax = ymax),
inherit.aes = FALSE,
alpha = 0.18,
fill = "skyblue"
) +
geom_line(
data = citywide_weekly,
aes(x = week_start_date, y = citywide_dengue_cases),
linewidth = 0.8
) +
labs(
title = "City-Wide Weekly Dengue Cases in Cebu City",
subtitle = "Wet season (June–November) is shaded in blue",
x = "Week",
y = "Total dengue cases across all barangays",
caption = "Source: FINAL_DATASET.xlsx | Weekly city-wide aggregation of barangay dengue cases"
) +
scale_x_date(
date_breaks = "1 year",
date_labels = "%Y"
) +
scale_y_continuous(labels = comma) +
theme_minimal() +
theme(
plot.title = element_text(face = "bold", size = 15),
plot.subtitle = element_text(size = 11),
axis.text.x = element_text(angle = 45, hjust = 1)
)
print(plot_weekly)
ggsave(
filename = file.path(output_dir, "citywide_weekly_dengue_timeseries_wet_season.png"),
plot = plot_weekly,
width = 12,
height = 6.5,
dpi = 300
)
# ------------------------------------------------------------
# 7. AGGREGATE TO MONTHLY CITY-WIDE CASES
# ------------------------------------------------------------
citywide_monthly <- citywide_weekly %>%
mutate(
year_month = floor_date(week_start_date, unit = "month"),
month_num = month(week_start_date),
month_name = month(week_start_date, label = TRUE, abbr = FALSE)
) %>%
group_by(year_month, month_num, month_name) %>%
summarise(
monthly_dengue_cases = sum(citywide_dengue_cases, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(year_month)
# ------------------------------------------------------------
# 8. CREATE AVERAGE MONTHLY PROFILE ACROSS ALL YEARS
# ------------------------------------------------------------
monthly_seasonality <- citywide_monthly %>%
group_by(month_num, month_name) %>%
summarise(
mean_monthly_cases = mean(monthly_dengue_cases, na.rm = TRUE),
sd_monthly_cases   = sd(monthly_dengue_cases, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(month_num) %>%
mutate(
wet_season = ifelse(month_num %in% 6:11, "Wet season", "Dry season")
)
# ------------------------------------------------------------
# 9. PLOT 2: AVERAGE MONTHLY DENGUE CASES
# This is often the clearest way to show seasonality
# ------------------------------------------------------------
plot_monthly <- ggplot(monthly_seasonality, aes(x = month_num, y = mean_monthly_cases)) +
geom_col(aes(fill = wet_season), width = 0.8) +
geom_errorbar(
aes(
ymin = pmax(mean_monthly_cases - sd_monthly_cases, 0),
ymax = mean_monthly_cases + sd_monthly_cases
),
width = 0.2
) +
scale_x_continuous(
breaks = 1:12,
labels = month.name
) +
scale_y_continuous(labels = comma) +
labs(
title = "Average Monthly Dengue Cases in Cebu City",
subtitle = "Monthly city-wide dengue pattern across all study years",
x = "Month",
y = "Average monthly dengue cases",
fill = "",
caption = "Bars show mean monthly dengue cases; error bars show ±1 SD"
) +
theme_minimal() +
theme(
plot.title = element_text(face = "bold", size = 15),
plot.subtitle = element_text(size = 11),
axis.text.x = element_text(angle = 45, hjust = 1)
)
print(plot_monthly)
ggsave(
filename = file.path(output_dir, "citywide_monthly_dengue_seasonality.png"),
plot = plot_monthly,
width = 11,
height = 6.5,
dpi = 300
)
# ------------------------------------------------------------
# 10. CREATE AVERAGE WEEKLY SEASONAL PROFILE (ISO WEEK)
# ------------------------------------------------------------
weekly_seasonality <- citywide_weekly %>%
group_by(week) %>%
summarise(
mean_weekly_cases = mean(citywide_dengue_cases, na.rm = TRUE),
sd_weekly_cases   = sd(citywide_dengue_cases, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(week)
# Approximate wet season ISO weeks: around weeks 23 to 48
weekly_seasonality <- weekly_seasonality %>%
mutate(
season_type = ifelse(week >= 23 & week <= 48, "Wet season", "Dry season")
)
# ------------------------------------------------------------
# 11. PLOT 3: AVERAGE WEEKLY SEASONAL PROFILE
# ------------------------------------------------------------
plot_week_profile <- ggplot(weekly_seasonality, aes(x = week, y = mean_weekly_cases)) +
annotate(
"rect",
xmin = 23, xmax = 48,
ymin = -Inf, ymax = Inf,
alpha = 0.18,
fill = "skyblue"
) +
geom_line(linewidth = 1) +
geom_ribbon(
aes(
ymin = pmax(mean_weekly_cases - sd_weekly_cases, 0),
ymax = mean_weekly_cases + sd_weekly_cases
),
alpha = 0.2
) +
labs(
title = "Average Weekly Dengue Pattern in Cebu City",
subtitle = "Mean city-wide dengue cases by ISO week; wet season approximately shaded",
x = "ISO week",
y = "Average city-wide dengue cases",
caption = "Line shows mean across years; ribbon shows ±1 SD"
) +
scale_x_continuous(breaks = seq(1, 52, by = 4)) +
scale_y_continuous(labels = comma) +
theme_minimal() +
theme(
plot.title = element_text(face = "bold", size = 15),
plot.subtitle = element_text(size = 11)
)
print(plot_week_profile)
ggsave(
filename = file.path(output_dir, "citywide_weekly_dengue_seasonal_profile.png"),
plot = plot_week_profile,
width = 11,
height = 6.5,
dpi = 300
)
# ------------------------------------------------------------
# 12. OPTIONAL: SAVE CITY-WIDE WEEKLY DATA
# ------------------------------------------------------------
write.csv(
citywide_weekly,
file.path(output_dir, "citywide_weekly_dengue_cases.csv"),
row.names = FALSE
)
write.csv(
citywide_monthly,
file.path(output_dir, "citywide_monthly_dengue_cases.csv"),
row.names = FALSE
)
write.csv(
monthly_seasonality,
file.path(output_dir, "citywide_monthly_dengue_seasonality_summary.csv"),
row.names = FALSE
)
write.csv(
weekly_seasonality,
file.path(output_dir, "citywide_weekly_dengue_seasonality_summary.csv"),
row.names = FALSE
)
# ------------------------------------------------------------
# 13. DONE MESSAGE
# ------------------------------------------------------------
cat("\nDONE! Temporal dengue plots saved in:\n")
cat(output_dir, "\n\n")
cat("Files created:\n")
cat("1. citywide_weekly_dengue_timeseries_wet_season.png\n")
cat("2. citywide_monthly_dengue_seasonality.png\n")
cat("3. citywide_weekly_dengue_seasonal_profile.png\n")
cat("4. citywide_weekly_dengue_cases.csv\n")
cat("5. citywide_monthly_dengue_cases.csv\n")
cat("6. citywide_monthly_dengue_seasonality_summary.csv\n")
cat("7. citywide_weekly_dengue_seasonality_summary.csv\n")
source("~/.active-rstudio-document")
source("~/.active-rstudio-document")
source("~/.active-rstudio-document")
source("~/.active-rstudio-document")
source("~/.active-rstudio-document")
